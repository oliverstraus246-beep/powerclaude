{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "command": "node -e \"const p=process.env.CLAUDE_TOOL_FILE||'';if(!p.match(/\\.(ts|tsx|js|jsx)$/))process.exit(0);const {execSync}=require('child_process');try{execSync('npx prettier --write \"'+p+'\"',{stdio:'pipe'})}catch(e){}\"",
        "description": "Format TypeScript/JS files with Prettier after edit"
      },
      {
        "matcher": "Write|Edit",
        "command": "node -e \"const p=process.env.CLAUDE_TOOL_FILE||'';if(!p.match(/\\.(ts|tsx)$/))process.exit(0);const {execSync}=require('child_process');try{execSync('timeout 60 npx tsc --noEmit --pretty false --incremental --tsBuildInfoFile node_modules/.cache/tsc-hook.tsbuildinfo 2>&1',{stdio:'pipe',timeout:65000})}catch(e){console.error(e.stdout?.toString())}\"",
        "description": "Incremental TypeScript type check after edit (60s timeout)"
      }
    ]
  }
}
