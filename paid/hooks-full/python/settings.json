{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "command": "node -e \"const p=process.env.CLAUDE_TOOL_FILE||'';if(!p.match(/\\.py$/))process.exit(0);const {execSync}=require('child_process');try{execSync('black \"'+p+'\" --quiet',{stdio:'pipe'})}catch(e){}try{execSync('isort \"'+p+'\" --quiet',{stdio:'pipe'})}catch(e){}\"",
        "description": "Format Python files with black and isort after edit"
      }
    ]
  }
}
